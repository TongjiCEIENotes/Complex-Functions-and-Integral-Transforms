    headfont=\color{RoyalPurple}\bfseries,
    bodyfont=\normalfont\color{black},
    spaceabove=3pt,
    spacebelow=3pt,
    headformat=\NOTE,
    headpunct={},
    notebraces={}{\newline}
]{headlesstheorem}
