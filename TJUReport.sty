%===========================================================================
% TJUReport 样式包 - 用于学科例题整理
%===========================================================================
% 本样式包提供了一套完整的例题整理文档格式
%
% 【主要功能】
% 1. 页面设置：A4纸张，2.5cm页边距
% 2. 数学环境：支持完整的数学公式排版
% 3. 图表支持：支持插入图片、表格
% 4. 彩色文本框：用于突出显示题目
% 5. 参考文献：支持BibTeX参考文献管理
% 6. 页眉设置：可自定义页眉logo
% 7. 封面模板：可选的封面页设置
%
% 【修改封面信息】
% 在本文件的第103-122行修改封面的个人信息（学院、专业、学号、姓名等）
%
% 【修改页眉logo】
% 在本文件的第95行修改页眉左侧的logo图片路径
%
% 【修改颜色主题】
% tcolorbox的颜色可以在main.tex中的tcolorbox环境中修改
% 例如：colback=cyan!10!white（背景色），colframe=cyan!80!black（边框色）
%===========================================================================

\ProvidesPackage{TJUReport}

%%页边距
\RequirePackage[left=2.50cm, right=2.50cm, top=2.50cm, bottom=2.50cm]{geometry}

%%一些必要的宏包
\RequirePackage[unicode=true,colorlinks,urlcolor=blue,linkcolor=blue,bookmarksnumbered=blue]{hyperref}
\RequirePackage{latexsym,amssymb,amsmath,amsbsy,amsopn,amstext,amsthm,amsxtra,color,bm,calc,ifpdf}
\RequirePackage{graphicx}
\RequirePackage{enumerate}
\RequirePackage{fancyhdr}
\RequirePackage{listings}
\RequirePackage{multirow}
\RequirePackage{makeidx}
\RequirePackage{needspace}

\PassOptionsToPackage{dvipsnames}{xcolor}
\RequirePackage{xcolor}

\RequirePackage{pdfpages}
\RequirePackage{fontspec}
\RequirePackage{subfigure}
\PassOptionsToPackage{hyphens}{url}
\RequirePackage{hyperref}
\RequirePackage{pythonhighlight}
\RequirePackage{booktabs}
%原来是\usepackage{tcolorbox}，改为下面这一行(editby高鹏，2026/1/29)
\RequirePackage[most]{tcolorbox}

%以下加了Note环境和编号环境(editby高鹏，2026/1/29)
\RequirePackage{thmtools}
\RequirePackage[shortlabels,inline]{enumitem}
%% note 环境（带左侧线与底色）
% \declaretheoremstyle: 定义定理类样式（标题/正文/间距）
\declaretheoremstyle[
    headfont=\color{orange!80}\bfseries, % 标题字体与颜色
    bodyfont=\normalfont\color{black},  % 正文字体（重置颜色）
    spaceabove=3pt,                     % 环境前间距
    spacebelow=3pt,                     % 环境后间距
    headformat=\NOTE,                   % 标题内容（此处仅显示可选标题）
    headpunct={},                       % 标题后不额外插入符号
    notebraces={}{\newline}             % 有标题才换行
]{notestyle}

% \declaretheorem: 定义 note 环境（有编号/无编号）
\declaretheorem[style=notestyle, name=Note, numbered=yes, numberwithin=section]{note} % 编号版
\declaretheorem[style=notestyle, name={}, numbered=no]{note*}                        % 无编号版

% \tcolorboxenvironment: 给 note 环境添加左侧线与底色
\tcolorboxenvironment{note}{%
    enhanced, breakable,               % 允许跨页
    sharp corners,                     % 直角边框
    leftrule=2pt, rightrule=0pt,        % 仅左侧有边线
    toprule=0pt, bottomrule=0pt,        % 上下边线不显示
    colframe=Orange,                   % 左侧边线颜色
    colback=Orange!8,                  % 背景底色
    before=\Needspace{5\baselineskip}, % 避免整体跨页
    coltext=black                      % 正文字色
}
\tcolorboxenvironment{note*}{%
    enhanced, breakable,               % 允许跨页
    rounded corners,                   % 圆角边框
    leftrule=2pt, rightrule=0pt,        % 仅左侧有边线
    toprule=0pt, bottomrule=0pt,        % 上下边线不显示
    colframe=Orange,                   % 左侧边线颜色
    colback=Orange!8,                  % 背景底色
    before=\Needspace{5\baselineskip}, % 避免整体跨页
    coltext=black                      % 正文字色
}
%以上加了note环境（editby高鹏，2026/1/29）

% ===== 下面是有颜色的定理类环境（editby高鹏，2026/1/29）
% 说明：保留原有大写 Theorem/Lemma 等，不删除；这里只新增有颜色的环境，使用时用小写就行
\declaretheorem[style=plain, name=定理, numbered=yes, numberwithin=section]{theorem}
\declaretheorem[style=plain, name=定理, numbered=no]{theorem*}

\declaretheorem[style=plain, name=命题, numbered=yes, sibling=theorem]{proposition}
\declaretheorem[style=plain, name=命题, numbered=no]{proposition*}

\declaretheorem[style=plain, name=推论, numbered=yes, sibling=theorem]{corollary}
\declaretheorem[style=plain, name=推论, numbered=no]{corollary*}

\declaretheorem[style=plain, name=引理, numbered=yes, sibling=theorem]{lemma}
\declaretheorem[style=plain, name=引理, numbered=no]{lemma*}

\declaretheorem[style=plain, name=断言, numbered=yes, sibling=theorem]{claim}
\declaretheorem[style=plain, name=断言, numbered=no]{claim*}

\declaretheorem[style=definition, name=定义, numbered=yes, numberwithin=section]{definition}
\declaretheorem[style=definition, name=定义, numbered=no]{definition*}

\declaretheorem[style=definition, name=例, numbered=yes, numberwithin=section]{example}
\declaretheorem[style=definition, name=例, numbered=no]{example*}

\declaretheorem[style=definition, name=题, numbered=yes, numberwithin=section]{problem}
\declaretheorem[style=definition, name=题, numbered=no]{problem*}

\declaretheorem[style=remark, name=注, numbered=yes, numberwithin=section]{remark}
\declaretheorem[style=remark, name=注, numbered=no]{remark*}
%(by高鹏，2026/2/13)
\newtheoremstyle{solutionstyle}%
  {3pt}   % 上间距
  {3pt}   % 下间距
  {\normalfont}  % 正文字体
  {}      % 缩进
  {\bfseries}    % 标题字体
  {.}     % 标题后标点
  { }     % 标题后空格
  {}      % 标题格式
\theoremstyle{solutionstyle}
\newtheorem{solution}{解}[section]
\newtheorem*{solution*}{解}
