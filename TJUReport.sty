    headfont=\color{NavyBlue}\bfseries,
    bodyfont=\normalfont\color{black},
    spaceabove=3pt,
    spacebelow=3pt,
    headformat=\NOTE,
    headpunct={},
    notebraces={}{\newline}
]{headlessblue}
\declaretheoremstyle[
    headfont=\color{ForestGreen}\bfseries,
    bodyfont=\normalfont\color{black},
    spaceabove=3pt,
    spacebelow=3pt,
    headformat=\NOTE,
    headpunct={},
    notebraces={}{\newline}
]{headlessgreen}
\declaretheoremstyle[
    headfont=\color{RawSienna}\bfseries,
    bodyfont=\normalfont\color{black},
    spaceabove=3pt,
    spacebelow=3pt,
    headformat=\NOTE,
    headpunct={},
    notebraces={}{\newline}
]{headlessbrown}
\declaretheoremstyle[
    headfont=\color{WildStrawberry}\bfseries,
    bodyfont=\normalfont\color{black},
    spaceabove=3pt,
    spacebelow=3pt,
    headformat=\NOTE,
    headpunct={},
    notebraces={}{\newline}
]{headlesspink}

\declaretheorem[style=headlesstheorem, name={}, numbered=no]{theoremh}
\declaretheorem[style=headlesstheorem, name={}, numbered=no]{propositionh}
\declaretheorem[style=headlessblue, name={}, numbered=no]{corollaryh}
\declaretheorem[style=headlessblue, name={}, numbered=no]{lemmah}
\declaretheorem[style=headlessblue, name={}, numbered=no]{claimh}
\declaretheorem[style=headlessgreen, name={}, numbered=no]{definitionh}
\declaretheorem[style=headlessbrown, name={}, numbered=no]{exampleh}
\declaretheorem[style=headlesspink, name={}, numbered=no]{problemh}
\declaretheorem[style=headlesspink, name={}, numbered=no]{remarkh}
\declaretheorem[style=headlesstheorem, name={}, numbered=no]{solutionh}

